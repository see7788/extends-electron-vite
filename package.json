{
  "name": "extends-electron-vite",
  "version": "1.0.1",
  "type": "module",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"extends-codex restart\" \"pnpm --dir mainapp exec electron-vite dev --watch --remoteDebuggingPort %npm_package_config_electronRemoteDebuggingPort%\""
  },
  "config": {
    "electronRemoteDebuggingPort": "9222"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "react": "^19.2.1",
      "react-dom": "^19.2.1",
      "react-router-dom": "^7.6.3",
      "hono": "^4.9.8",
      "@hono/node-server": "^1.13.8",
      "vite": "^7.2.6",
      "electron": "^39.2.6",
      "electron-vite": "^5.0.0",
      "tsx": "^4.20.0",
      "typescript": "^5.9.3"
    }
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
