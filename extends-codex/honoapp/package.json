{
  "name": "honoapp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./*/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --external vscode --external typescript --external ts-morph"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.1",
    "@hono/zod-validator": "^0.8.0",
    "@modelcontextprotocol/sdk": "0.6.0",
    "@openai/codex-sdk": "^0.136.0",
    "extends-hono": "workspace:*",
    "extends-zustand": "workspace:*",
    "hono": "^4.12.18",
    "imapflow": "^1.3.3",
    "immer": "10.2.0",
    "mailparser": "^3.9.8",
    "openai": "^6.37.0",
    "ts-morph": "^28.0.0",
    "typescript": "5.9.3",
    "zod": "^4.4.3",
    "zustand": "5.0.13",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.19.40",
    "@types/vscode": "^1.120.0",
    "tsup": "^8.5.1"
  },
  "files": [
    "bin/",
    "src/",
    "dist/",
    "index.d.ts"
  ]
}
